{
  "name": "manhattan-client",
  "version": "1.0.0",
  "description": "Manhattan - Real-time E2EE group chat client",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run bundle && npx http-server . -p 3000 -c-1",
    "bundle": "esbuild src/main.js --bundle --outfile=dist/bundle.js --format=esm --platform=browser --sourcemap",
    "bundle:watch": "esbuild src/main.js --bundle --outfile=dist/bundle.js --format=esm --platform=browser --sourcemap --watch",
    "build": "npx tailwindcss -i ./src/input.css -o ./dist/output.css --minify && npm run bundle",
    "build:watch": "npx tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.0.0",
    "argon2-browser": "^1.18.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@playwright/test": "^1.42.0",
    "autoprefixer": "^10.4.17",
    "esbuild": "^0.28.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.35"
  },
  "keywords": [
    "chat",
    "e2ee",
    "websocket",
    "encryption"
  ],
  "license": "MIT"
}
